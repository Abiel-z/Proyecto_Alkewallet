<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProfilePage">

    <ImageView
        android:id="@+id/img_rect_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:srcCompat="@drawable/background_rectangle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/img_fondo_profile_page"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/profile_rectangle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txt_miperfil_profile_page"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:text="@string/perfil_miperfil"
        android:textSize="20sp"
        android:fontFamily="@font/fuente_alkewallet"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/img_fondo_profile_page" />

    <ImageView
        android:id="@+id/img_icono_editar_profile_page"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        app:layout_constraintHorizontal_bias="0.9"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        app:srcCompat="@drawable/edit_icon"/>

    <ImageView
        android:id="@+id/img_fotoperfil_profile_page"
        android:layout_width="112dp"
        android:layout_height="101dp"
        android:layout_marginTop="35dp"
        android:src="@drawable/profile_picture2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_miperfil_profile_page" />

    <TextView
        android:id="@+id/txt_nombre_profile_page"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Amanda Alkemy"
        android:textSize="20sp"
        android:fontFamily="@font/fuente_alkewallet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_fotoperfil_profile_page" />

    <LinearLayout
        android:id="@+id/lay_opciones_profile_page"
        android:layout_width="351dp"
        android:layout_height="305dp"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_fondo_profile_page">

        <LinearLayout
            android:id="@+id/lay_btn_miinfo_profile_page"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="@drawable/perfil_btn_rectangle"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/img_icono_miinfo_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                app:srcCompat="@drawable/profile_icon" />

            <TextView
                android:id="@+id/txt_miinfo_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="5"
                android:text="@string/perfil_miinformacion"
                android:fontFamily="@font/fuente_alkewallet"/>

            <ImageView
                android:id="@+id/img_arrow_miinfo_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                app:srcCompat="@drawable/arrow_icon" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lay_btn_mistarjetas_profile_page"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="@drawable/perfil_btn_rectangle"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/img_icono_mistarjetas_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                tools:srcCompat="@drawable/card_icon" />

            <TextView
                android:id="@+id/txt_mistarjetas_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="5"
                android:text="@string/perfil_mistarjetas"
                android:fontFamily="@font/fuente_alkewallet"/>

            <ImageView
                android:id="@+id/img_arrow_mistarjetas_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                app:srcCompat="@drawable/arrow_icon" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lay_btn_opciones_profile_page"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="@drawable/perfil_btn_rectangle"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/img_icono_opciones_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                tools:srcCompat="@drawable/settings_icon" />

            <TextView
                android:id="@+id/txt_opciones_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="5"
                android:text="@string/perfil_opciones"
                android:fontFamily="@font/fuente_alkewallet"/>

            <ImageView
                android:id="@+id/img_arrow_opciones_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                app:srcCompat="@drawable/arrow_icon" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/lay_centroayuda_profile_page"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:layout_weight="1"
            android:background="@drawable/perfil_btn_rectangle"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/img_icono_centroayuda_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                tools:srcCompat="@drawable/help_icon" />

            <TextView
                android:id="@+id/txt_centroayuda_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="5"
                android:text="@string/perfil_centroayuda"
                android:fontFamily="@font/fuente_alkewallet" />

            <ImageView
                android:id="@+id/img_arrow_centroayuda_profile_page"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                app:srcCompat="@drawable/arrow_icon" />

        </LinearLayout>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>